# Supabase Configuration
# Replace these values with your actual project details from the Supabase dashboard
VITE_SUPABASE_URL=your-project-url-here.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (used by /api functions, never exposed to the client bundle).
# Do NOT prefix these with VITE_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL="DreamBridge <notify@your-verified-domain>"
APP_URL=https://your-deployed-domain
# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`;
# set the same value in the Vercel project's environment variables.
CRON_SECRET=your-random-secret-here
